# Jury Hopps — environment variables (names only; see specs/09-infra-and-keys.md)
# Copy to .env locally. NEVER commit real values.

# ── council-service (Fly.io secrets) ─────────────────────────────
ANTHROPIC_API_KEY=            # Anthropic Console — Chair, jurors, judge, web search tool
VOYAGE_API_KEY=               # Voyage AI — voyage-3 embeddings
SUPABASE_URL=                 # Supabase project settings
SUPABASE_SERVICE_ROLE_KEY=    # Supabase — full read/write; service only, never client-side
COUNCIL_SERVICE_TOKEN=        # self-issued random 32-byte bearer token
TAVILY_API_KEY=               # OPTIONAL — only if Anthropic server-side search unavailable
COST_CAP_USD=0.50             # per-session kill-switch
DEMO_MODE=0                   # 1 = stream golden fixture instead of live deliberation

# ── web (Vercel) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=     # public; replay pages read finished sessions
NEXT_PUBLIC_SUPABASE_ANON_KEY=# public; read-only under RLS
COUNCIL_SERVICE_URL=          # server-only; proxy route target
# COUNCIL_SERVICE_TOKEN also set here, server-only — no NEXT_PUBLIC_ prefix, ever
